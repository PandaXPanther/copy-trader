# --- Discord ---
# Webhook for paper-fill alerts and daily summaries
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# --- Hyperliquid ---
# Mainnet API base (no key needed for read-only / public data)
HL_API_BASE=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# --- Paper trading config ---
# Starting paper equity in USD
PAPER_STARTING_EQUITY_USD=10000

# Max % of paper equity to allocate to any single copied position
PAPER_MAX_POSITION_PCT=10

# Global daily loss limit (% of equity). Bot halts copies for the day if breached.
PAPER_DAILY_LOSS_LIMIT_PCT=5

# Max leverage to ever take, regardless of what the source wallet does
PAPER_MAX_LEVERAGE=10

# Skip copy if 1h funding rate (annualized %) exceeds this
PAPER_MAX_FUNDING_APR_PCT=200

# Per-wallet max equity allocation (%)
PAPER_PER_WALLET_CAP_PCT=25

# --- Scorer config ---
# How many days of fill history to fetch per wallet when scoring
SCORER_LOOKBACK_DAYS=90

# Min trades in lookback window to even rank a wallet
SCORER_MIN_TRADES=20

# How often to re-score all wallets (minutes)
SCORER_REFRESH_MINUTES=360

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
DATA_DIR=./data
